.order-card { background: #fff; margin: 16rpx; border-radius: 12rpx; overflow: hidden; }
.order-header { display: flex; justify-content: space-between; padding: 20rpx; font-size: 24rpx; color: #666; border-bottom: 1rpx solid #f5f5f5; }
.status { color: #07c160; }
.order-body { padding: 20rpx; display: flex; justify-content: space-between; }
.amount { font-size: 36rpx; font-weight: bold; color: #f56c6c; }
.time { font-size: 24rpx; color: #999; }
.order-footer { text-align: right; padding: 0 20rpx 20rpx; }
.cancel-btn { font-size: 24rpx; color: #999; padding: 8rpx 24rpx; border-radius: 8rpx; }
