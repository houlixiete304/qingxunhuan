<view class="page">
  <view class="logo-area">
    <image class="logo" src="/images/tab/home-active.png" mode="aspectFit" />
    <text class="app-name">青循环</text>
    <text class="slogan">校园二手交易平台</text>
  </view>

  <view class="login-area">
    <button class="login-btn quick" bindtap="onQuickLogin">一键登录</button>
    <button class="login-btn wx" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">微信授权登录</button>
  </view>
</view>
