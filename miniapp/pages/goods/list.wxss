.goods-list { display: flex; flex-wrap: wrap; padding: 10rpx; }
.goods-card { width: 48%; margin: 1%; background: #fff; border-radius: 12rpx; overflow: hidden; }
.info { padding: 16rpx; }
.title { font-size: 28rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bottom { display: flex; justify-content: space-between; margin-top: 10rpx; }
.price { font-size: 32rpx; color: #f56c6c; font-weight: bold; }
.views { font-size: 22rpx; color: #999; }
.no-more { text-align: center; color: #999; font-size: 24rpx; padding: 20rpx; }
