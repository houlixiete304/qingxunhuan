.page {
  display: flex;
  height: 100vh;
}
.sidebar {
  width: 200rpx;
  background: #f5f5f5;
  overflow-y: auto;
}
.sidebar-item {
  padding: 30rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}
.sidebar-item.active {
  background: #fff;
  color: #07c160;
  font-weight: bold;
}
.content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
  align-content: flex-start;
  background: #fff;
}
.sub-item {
  width: 33.3%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}
.sub-item text {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}
