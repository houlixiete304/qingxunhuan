.page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }
.msg-list { flex: 1; padding: 20rpx; overflow-y: auto; }
.msg-item { margin-bottom: 24rpx; display: flex; flex-direction: column; align-items: flex-start; }
.msg-item.self { align-items: flex-end; }
.msg-bubble { max-width: 80%; padding: 16rpx 24rpx; border-radius: 16rpx; font-size: 28rpx; background: #fff; }
.msg-item.self .msg-bubble { background: #95ec69; }
.msg-time { font-size: 20rpx; color: #ccc; margin-top: 6rpx; }
.input-bar { display: flex; align-items: center; padding: 16rpx; background: #fff; border-top: 1rpx solid #eee; }
.input { flex: 1; height: 72rpx; background: #f5f5f5; border-radius: 36rpx; padding: 0 24rpx; font-size: 28rpx; }
.send-btn { width: 120rpx; height: 64rpx; line-height: 64rpx; text-align: center; background: #07c160; color: #fff; border-radius: 32rpx; font-size: 26rpx; margin-left: 16rpx; padding: 0; }
